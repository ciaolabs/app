{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "platform",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "platform", "dev"],
      "port": 3000
    },
    {
      "name": "platform-autoport",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "platform", "exec", "next", "dev"],
      "autoPort": true
    }
  ]
}
