{
  "name": "ciaobang",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:survey": "pnpm --filter survey dev",
    "dev:app": "pnpm --filter app dev",
    "dev:docs": "pnpm --filter docs dev",
    "build": "pnpm -r build",
    "build:survey": "pnpm --filter survey build",
    "build:app": "pnpm --filter app build",
    "build:docs": "pnpm --filter docs build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
