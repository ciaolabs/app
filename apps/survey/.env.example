# --- WorkOS auth (values MUST be identical in apps/app for cross-subdomain SSO) ---
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# Must be at least 32 characters. MUST be identical to apps/app's value.
WORKOS_COOKIE_PASSWORD=
# Cookie domain that lets survey.ciaobang.com and app.ciaobang.com share the WorkOS session cookie.
# Local dev: ".ciaobang.local"   Production: ".ciaobang.com"
WORKOS_COOKIE_DOMAIN=.ciaobang.local
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# --- Cross-app links ---
# Where the chat lives. /chat on this app redirects here.
NEXT_PUBLIC_APP_URL=http://app.ciaobang.local:3001
# Optional explicit HMAC secret for app -> survey context lookups. If omitted,
# WORKOS_COOKIE_PASSWORD is used. Must match apps/app.
SURVEY_CONTEXT_SECRET=

# --- Database ---
# DATABASE_URL is preferred. POSTGRES_URL / POSTGRES_PRISMA_URL are also accepted.
# Use the same production database URL in apps/survey and apps/app.
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
SURVEY_STORAGE=memory
