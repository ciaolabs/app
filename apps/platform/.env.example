# --- WorkOS auth ---
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# Must be at least 32 characters. Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=
# Single-host deployment: the cookie domain can stay unset (host-only cookie).
# Set it only if other ciaobang.com subdomains must share the session.
WORKOS_COOKIE_DOMAIN=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# --- Database ---
# DATABASE_URL is preferred. POSTGRES_URL / POSTGRES_PRISMA_URL are also accepted
# for Vercel-managed Postgres/Supabase integrations.
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
SURVEY_STORAGE=memory

# Note: user-provided AI API keys are NOT stored server-side. They live only in
# the user's browser (localStorage) and are sent per request, so no encryption
# secret is needed for them.

# --- AI ---
AI_GATEWAY_API_KEY=
VERCEL_AI_GATEWAY_MODEL=google/gemini-2.5-flash

# --- Docs indexing (operator task: pnpm --filter platform index) ---
# Embedding key used only by scripts/index-docs.ts, not by chat requests.
RAG_GOOGLE_API_KEY=
