# --- WorkOS auth (values MUST be identical in apps/survey for cross-subdomain SSO) ---
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# Must be at least 32 characters. MUST be identical to apps/survey's value.
WORKOS_COOKIE_PASSWORD=
# Cookie domain that lets survey.ciaobang.com and app.ciaobang.com share the WorkOS session cookie.
WORKOS_COOKIE_DOMAIN=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3001/callback

# --- Cross-app links ---
# Survey app URL. Used for the "back to surveys" link AND for the server-side fetch
# that loads survey context for chat personalization.
NEXT_PUBLIC_SURVEY_URL=http://survey.ciaobang.local:3000
# Optional override for the server-to-server URL (defaults to NEXT_PUBLIC_SURVEY_URL).
# Useful in production if you want chat to reach survey via an internal hostname.
SURVEY_INTERNAL_URL=
# Optional explicit HMAC secret for app -> survey context lookups. If omitted,
# WORKOS_COOKIE_PASSWORD is used. Must match apps/survey.
SURVEY_CONTEXT_SECRET=

# --- Database ---
# DATABASE_URL is preferred. POSTGRES_URL / POSTGRES_PRISMA_URL are also accepted
# for Vercel-managed Postgres/Supabase integrations. Use the same production
# database URL in apps/app and apps/survey so account, chat, and survey state
# resolve the same app_private.user_accounts and research.submissions rows.
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
SURVEY_STORAGE=memory

# --- API key encryption ---
# Encrypts participant BYOK API keys at rest. Must be ≥32 characters.
# Generate with: openssl rand -base64 32
API_KEY_ENCRYPTION_SECRET=

# --- AI ---
AI_GATEWAY_API_KEY=
VERCEL_AI_GATEWAY_MODEL=google/gemini-2.5-flash
